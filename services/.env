# ===================================
# HS Aalen AI Search - Configuration
# ===================================

# Scheduler Configuration
SCHEDULER_INTERVAL_DAYS=14
CONTAINER_SOCKET_PATH=/var/run/docker.sock

# Website Scraper
TARGET_URLS=https://www.hs-aalen.de,https://www.hs-aalen.de/studium,https://www.hs-aalen.de/department
MAX_DEPTH=3
TIMEOUT_MINUTES=120

# PDF Indexer
PDF_SOURCES=/data/pdf_sources

# Timetable Scraper
TIMETABLE_API_URL=https://hochschulportal.hs-aalen.de

# Text Processing
CHUNK_SIZE=512
OVERLAP=50

# Embeddings (Ollama)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_MODEL_LLM=deepseek-r1:8b

# Qdrant
QDRANT_HOST=qdrant-db
QDRANT_PORT=6333
COLLECTIONS=hs_aalen_search,hs_aalen_website,timetable_data

# Search API
API_PORT=8055
API_HOST=0.0.0.0

# Directories
INPUT_DIR=/data/raw
PROCESSED_DIR=/data/processed
EMBEDDINGS_DIR=/data/embeddings
OUTPUT_DIR=/data
